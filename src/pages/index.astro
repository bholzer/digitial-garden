---
import BaseLayout from '../layouts/BaseLayout.astro';
import SummaryCard from '../components/SummaryCard.astro';
const name = 'Brennan Holzer';
---
<BaseLayout pageTitle={name}>
  <!-- Hero -->
  <section class="mx-auto max-w-4xl px-6 pt-16 pb-24">
    <h1 class="animate-fade-up font-display text-5xl font-bold tracking-tight text-primary sm:text-[3.5rem]">
      {name}
    </h1>
    <p
      class="animate-fade-up mt-4 font-display text-xl text-secondary/85 sm:text-[1.35rem]"
      style="animation-delay: 80ms"
    >
      Software developer, engineer, maker.
    </p>

    <div class="animate-fade-up mt-8 h-px w-12 bg-secondary/25" style="animation-delay: 160ms"></div>

    <p class="animate-fade-up mt-8 max-w-lg text-[15px] leading-[1.7] text-secondary/85" style="animation-delay: 240ms">
      I build digital tools that prioritize simplicity and performance. Currently exploring
      distributed systems and cultivating a digital garden of thoughts on software
      craftsmanship.
    </p>

    <!-- Social icons -->
    <div
      class="animate-fade-up mt-8 flex items-center gap-5"
      style="animation-delay: 320ms"
    >
      <a href="#" class="text-secondary transition-colors duration-200 hover:text-primary" aria-label="GitHub">
        <svg class="h-[18px] w-[18px]" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
      </a>
      <a href="#" class="text-secondary transition-colors duration-200 hover:text-primary" aria-label="Twitter">
        <svg class="h-[18px] w-[18px]" fill="currentColor" viewBox="0 0 24 24">
          <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
        </svg>
      </a>
      <a href="mailto:hello@example.com" class="text-secondary transition-colors duration-200 hover:text-primary" aria-label="Email">
        <svg class="h-[18px] w-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
        </svg>
      </a>
    </div>
  </section>

